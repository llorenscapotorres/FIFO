POSTGRES_USER=fifo_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=fifo_db
POSTGRES_PORT=5432

BACKEND_PORT=8000
SESSION_COOKIE_SECURE=false
SESSION_TTL_DAYS=30

FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Nightly backup: dumps the production Neon database into a local
# "fifo_db_backup" database inside this same docker-compose Postgres.
# Paste Neon's connection string as-is (postgresql://...); leave empty
# to disable the backup service.
NEON_DATABASE_URL=
BACKUP_DB_NAME=fifo_db_backup
